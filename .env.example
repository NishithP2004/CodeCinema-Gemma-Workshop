PORT=5177
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b

# TTS_PROVIDER can be auto, piper, say, or command.
TTS_PROVIDER=auto
PIPER_MODEL=/absolute/path/to/voice.onnx

# Optional generic command adapter. The command receives these env vars:
# CODECINEMA_TTS_INPUT and CODECINEMA_TTS_OUTPUT.
TTS_COMMAND=

# Optional Mermaid Chart API adapter.
MERMAID_CHART_API_URL=
MERMAID_CHART_API_KEY=
